    "@babel/preset-typescript": "^7.27.1",
    "@eslint/js": "^9.35.0",
    "@quasar/app-vite": "^2.4.0",
    "@qubit-ltd/eslint-config": "^2.0.1",
    "@qubit-ltd/jsdoc-theme": "^1.5.2",
