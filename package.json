    "autoprefixer": "^10.4.21",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-object-hasown": "^1.1.0",
    "core-js": "^3.45.1",
    "cross-env": "^10.0.0",
    "dotenv-flow": "^4.1.0",
    "electron": "^38.1.0",
    "eslint": "^9.35.0",
