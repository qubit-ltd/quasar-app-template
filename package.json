    "@qubit-ltd/common-normalizer": "^1.8.7",
    "@qubit-ltd/common-ui": "^1.15.3",
    "@qubit-ltd/common-ui-quasar": "^1.1.4",
    "@qubit-ltd/common-util": "^5.4.9",
    "@qubit-ltd/common-validator": "^4.10.3",
    "@qubit-ltd/config": "^1.2.5",
    "@qubit-ltd/json": "^1.2.6",
    "@qubit-ltd/logging": "^1.4.15",
    "@qubit-ltd/naming-style": "^1.3.12",
    "@qubit-ltd/pinia-decorator": "^3.4.5",
    "@qubit-ltd/storage": "^1.4.6",
    "@qubit-ltd/type-detect": "^2.2.8",
    "@qubit-ltd/typeinfo": "^3.3.9",
