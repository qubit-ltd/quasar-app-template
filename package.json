    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdoc": "^4.0.4",
    "postcss": "^8.5.6",
    "qs": "^6.14.0",
    "vite": "^7.1.5",
    "vite-plugin-generate-file": "^0.3.1",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "node": "^24 || ^22 || ^21 || ^20 || ^18",
    "npm": ">= 6.13.4",
