{
  "name": "quasar-app-template",
  "version": "1.2.0",
  "description": "A Quasar Project",
  "productName": "Quasar App",
  "author": "Haixing Hu <starfish.hu@gmail.com>",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/qubit-ltd/quasar-app-template.git"
  },
  "scripts": {
    "clean": "rm -rvf dist doc",
    "dev": "cross-env NODE_ENV=development quasar dev --debug",
    "dev:stage": "cross-env NODE_ENV=stage quasar dev --debug",
    "dev:local": "cross-env NODE_ENV=local quasar dev --debug",
    "dev:electron": "cross-env NODE_ENV=development quasar dev -m electron --debug",
    "build:prod": "cross-env NODE_ENV=production quasar build",
    "build:stage": "cross-env NODE_ENV=stage quasar build --debug",
    "build:dev": "cross-env NODE_ENV=development quasar build --debug",
    "build-electron:prod": "cross-env NODE_ENV=production quasar build -m electron",
    "build-electron:stage": "cross-env NODE_ENV=stage quasar build -m electron",
    "build-electron:dev": "cross-env NODE_ENV=development quasar build -m electron",
    "build-electron:local": "cross-env NODE_ENV=local quasar build -m electron",
    "test": "jest --passWithNoTests",
    "lint": "eslint ./src",
    "doc": "jsdoc -c jsdoc.json"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.5",
    "@quasar/extras": "^1.17.0",
    "@qubit-ltd/clone": "^1.13.6",
    "@qubit-ltd/common-api": "^3.4.4",
